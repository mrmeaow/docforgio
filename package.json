{
  "name": "folio",
  "version": "0.1.0",
  "description": "Open Document Studio - A free, open-source, browser-native document composition studio",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "document",
    "editor",
    "markdown",
    "html",
    "pdf",
    "tailwindcss"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@codemirror/basic-setup": "^0.20.0",
