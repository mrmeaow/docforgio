    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@dnd-kit/core": "^6.3.1",
    "idb": "^8.0.3",
    "immer": "^11.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "react": "19.0.0-rc.1",
    "react-dom": "19.0.0-rc.1",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.0.0",
    "zustand": "^5.0.12"
